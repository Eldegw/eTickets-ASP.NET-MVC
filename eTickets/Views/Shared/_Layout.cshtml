<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - eTickets</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700&family=Inter:wght@300;400;600&display=swap" rel="stylesheet">

    <style>
        :root {
            --main-red: #ff0000;
            --dark-red: #8b0000;
            --bg-black: #050505;
            --glass-bg: rgba(15, 15, 15, 0.85);
        }

        body {
            background-color: var(--bg-black);
            color: #ffffff;
            font-family: 'Inter', sans-serif;
            overflow-x: hidden;
        }

        .premium-nav {
            background: var(--glass-bg) !important;
            backdrop-filter: blur(20px);
            border-bottom: 1px solid rgba(255, 0, 0, 0.3);
            padding: 10px 0;
        }

        .navbar-brand {
            font-family: 'Orbitron', sans-serif;
            font-weight: 700;
            color: var(--main-red) !important;
            letter-spacing: 2px;
        }

        .nav-link {
            font-weight: 500 !important;
            transition: 0.3s;
            color: white !important;
        }

            .nav-link:hover {
                color: var(--main-red) !important;
                text-shadow: 0 0 8px rgba(255, 0, 0, 0.5);
            }

        .search-container {
            background: rgba(255, 255, 255, 0.07);
            border-radius: 30px;
            padding: 2px 15px;
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        .search-input {
            background: transparent !important;
            border: none !important;
            color: white !important;
            box-shadow: none !important;
        }

        .search-btn {
            color: var(--main-red) !important;
        }

        .dropdown-menu {
            background: rgba(20, 20, 20, 0.95) !important;
            backdrop-filter: blur(15px);
            border: 1px solid rgba(255, 0, 0, 0.3) !important;
            border-radius: 12px;
            padding: 8px;
        }

        .dropdown-item {
            color: #ccc !important;
            border-radius: 8px;
            padding: 10px 15px;
            transition: 0.3s;
        }

            .dropdown-item:hover {
                background: rgba(255, 0, 0, 0.15) !important;
                color: white !important;
                padding-left: 20px;
            }

        .footer-red {
            background: #000 !important;
            border-top: 1px solid #1a1a1a;
            padding: 30px 0;
            margin-top: 80px;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg premium-nav sticky-top">
            <div class="container-fluid px-lg-5">
                <a class="navbar-brand" asp-controller="Movies" asp-action="Index">
                    <i class="bi bi-ticket-perforated me-2"></i>eTICKETS
                </a>

                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                    <i class="bi bi-list text-white fs-2"></i>
                </button>

                <div class="collapse navbar-collapse" id="navbarContent">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Movies" asp-action="Index">
                                <i class="bi bi-film me-1"></i> Movies
                            </a>
                        </li>

                      
                        @if (User.Identity.IsAuthenticated && User.IsInRole("Admin"))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="mgmtDrop" role="button" data-bs-toggle="dropdown">
                                    <i class="bi bi-gear-wide-connected me-1"></i> Management
                                </a>
                                <ul class="dropdown-menu shadow-lg">
                                    <li>
                                        <a class="dropdown-item" asp-controller="Cinemas" asp-action="Index">
                                            <i class="bi bi-camera-reels me-2 text-danger"></i> Cinemas
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Producers" asp-action="Index">
                                            <i class="bi bi-headset me-2 text-danger"></i> Producers
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Actors" asp-action="Index">
                                            <i class="bi bi-person-badge me-2 text-danger"></i> Actors
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }
                    </ul>

                    <form class="d-flex search-container me-lg-3" asp-controller="Movies" asp-action="Filter">
                        <input name="searchString" type="text" class="form-control search-input" placeholder="Search movies..." />
                        <button class="btn search-btn" type="submit"><i class="bi bi-search"></i></button>
                    </form>

                 
                    <partial name="_Identity" />
                </div>
            </div>
        </nav>
    </header>

    <div class="container-fluid mt-4 px-lg-5">
        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <footer class="footer-red text-center">
        <div class="container">
            <p class="mb-0 text-secondary">&copy; 2026 - <span class="text-white fw-bold">eTICKETS</span></p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>