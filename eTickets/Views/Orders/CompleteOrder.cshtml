@{
    ViewData["Title"] = "Payment Successful";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    :root {
        --primary-red: #e50914;
        --success-green: #28a745;
        --glass-bg: rgba(255, 255, 255, 0.03);
        --glass-border: rgba(255, 255, 255, 0.08);
    }

    /* حاوية مخصصة لضمان التوسط في منتصف الـ RenderBody فقط */
    .page-content-wrapper {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 80vh; /* يضمن التوسط عمودياً */
        width: 100%;
        padding: 40px 0;
    }

    .glass-ticket {
        background: var(--glass-bg);
        backdrop-filter: blur(30px);
        -webkit-backdrop-filter: blur(30px);
        border: 1px solid var(--glass-border);
        border-radius: 30px;
        width: 100%;
        max-width: 480px;
        overflow: hidden;
        box-shadow: 0 40px 100px rgba(0,0,0,0.7);
        position: relative;
    }

    .ticket-header {
        background: linear-gradient(90deg, #b20710, var(--primary-red));
        padding: 12px;
        text-align: center;
        font-weight: 700;
        letter-spacing: 4px;
        font-size: 0.7rem;
        text-transform: uppercase;
        color: white;
    }

    .ticket-content {
        padding: 50px 40px;
        text-align: center;
        color: white;
    }

    /* أيقونة النجاح وكلمة SUCCESSFUL */
    .main-check-icon {
        font-size: 6rem;
        color: var(--success-green);
        line-height: 1;
        filter: drop-shadow(0 0 15px rgba(40, 167, 69, 0.4));
        margin-bottom: 10px;
        display: block;
    }

    .status-heading {
        font-size: 2.5rem;
        font-weight: 900;
        letter-spacing: 6px;
        color: #ffffff;
        margin-bottom: 30px;
    }

    .movie-name {
        font-size: 1.8rem;
        font-weight: 800;
        margin-bottom: 5px;
        text-transform: uppercase;
    }

    .order-ref {
        font-family: 'Monaco', monospace;
        color: #666;
        font-size: 0.85rem;
        background: rgba(255,255,255,0.05);
        padding: 5px 15px;
        border-radius: 5px;
    }

    .ticket-divider {
        height: 1px;
        border-top: 2px dashed rgba(255,255,255,0.1);
        margin: 35px 0;
        position: relative;
    }

        /* الثقوب الجانبية للتذكرة */
        .ticket-divider::before, .ticket-divider::after {
            content: '';
            position: absolute;
            top: -12px;
            width: 24px;
            height: 24px;
            background: #080808; /* نفس لون خلفية الـ Layout عندك */
            border-radius: 50%;
        }

        .ticket-divider::before {
            left: -53px;
        }

        .ticket-divider::after {
            right: -53px;
        }

    /* شبكة المعلومات */
    .info-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        text-align: left;
        margin-bottom: 40px;
    }

    .info-label {
        color: #555;
        font-size: 0.65rem;
        text-transform: uppercase;
        display: block;
    }

    .info-value {
        font-size: 0.9rem;
        font-weight: 600;
        color: #ddd;
    }

    /* الزر الرئيسي */
    .btn-action {
        background: #ffffff;
        color: #000 !important;
        border-radius: 15px;
        padding: 16px;
        font-weight: 800;
        text-decoration: none;
        display: block;
        transition: 0.3s;
        text-transform: uppercase;
        border: none;
    }

        .btn-action:hover {
            background: var(--primary-red);
            color: white !important;
            transform: translateY(-3px);
        }
</style>

<div class="page-content-wrapper">
    <div class="glass-ticket shadow-lg">
        <div class="ticket-header">
            E-TICKET SECURED • ADMIT ONE
        </div>

        <div class="ticket-content">
            <i class="bi bi-check-circle-fill main-check-icon"></i>
            <h1 class="status-heading">SUCCESSFUL</h1>

            <p class="text-muted small mb-1">YOUR TICKET IS READY FOR</p>
            <h2 class="movie-name">John Wick: Chapter 4</h2>
            <span class="order-ref">ORDER ID: #@Guid.NewGuid().ToString().Substring(0, 8).ToUpper()</span>

            <div class="ticket-divider"></div>

            <div class="info-grid">
                <div>
                    <span class="info-label">Status</span>
                    <span class="info-value text-success">Verified <i class="bi bi-patch-check-fill small"></i></span>
                </div>
                <div class="text-end">
                    <span class="info-label">Access</span>
                    <span class="info-value">Instant Digital</span>
                </div>
                <div>
                    <span class="info-label">Date</span>
                    <span class="info-value">@DateTime.Now.ToString("MMM dd, yyyy")</span>
                </div>
                <div class="text-end">
                    <span class="info-label">Location</span>
                    <span class="info-value">Cloud Library</span>
                </div>
            </div>

            <a asp-action="Index" asp-controller="Orders" class="btn-action shadow">
                <i class="bi bi-ticket-perforated-fill me-2"></i> ACCESS MY TICKETS
            </a>
            <div class="mt-3">
                <a asp-action="Index" asp-controller="Movies" class="text-muted small text-decoration-none">
                    Return to Cinema Lobby
                </a>
            </div>
        </div>
    </div>
</div>