@using eTickets.Data.ViewModels;
@model ShoppingCartVM

@{
    ViewData["Title"] = "Shopping Cart Summary";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<div class="container-fluid min-vh-100 py-5" style="background-color: #0f0f0f; color: #e0e0e0; font-family: 'Inter', sans-serif;">
    <div class="container">
        <div class="row">
            <div class="col-md-10 offset-md-1">

                <div class="d-flex justify-content-between align-items-end mb-5 pb-3 border-bottom" style="border-color: #2a2a2a !important;">
                    <h2 style="font-weight: 800; text-transform: uppercase; letter-spacing: 2px; margin-bottom: 0;">
                        <span style="color: #e63946;">MY</span> CART
                    </h2>
                    <a class="btn btn-outline-light btn-sm rounded-0 px-4" asp-controller="Movies" asp-action="Index"
                       style="border-color: #444; font-size: 0.75rem; letter-spacing: 1px; transition: 0.3s;">
                        <i class="bi bi-arrow-left me-2"></i> ADD MORE MOVIES
                    </a>
                </div>

                <div class="card border-0 shadow-lg rounded-4 overflow-hidden" style="background-color: #1a1a1a;">
                    <div class="table-responsive">
                        <table class="table table-dark table-hover mb-0 align-middle">
                            <thead style="background-color: #252525;">
                                <tr class="small text-uppercase" style="letter-spacing: 1.5px; color: #888;">
                                    <th class="ps-4 py-4 border-0">Selected Movie</th>
                                    <th class="text-center border-0">Price</th>
                                    <th class="text-center border-0">Quantity</th>
                                    <th class="text-center border-0">Subtotal</th>
                                    <th class="text-end pe-4 border-0">Manage</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.ShoppingCart.ShoppingCartItems)
                                {
                                    <tr style="border-bottom: 1px solid #252525; transition: 0.3s;">
                                        <td class="ps-4 py-4">
                                            <div class="fw-bold" style="font-size: 1.1rem; color: #fff;">@item.Movie.Name</div>
                                        </td>
                                        <td class="text-center text-secondary small">@item.Movie.Price.ToString("c")</td>
                                        <td class="text-center">
                                            <span class="px-3 py-1 rounded-pill" style="background: #252525; color: #fff; border: 1px solid #333; font-family: monospace;">
                                                @item.Amount
                                            </span>
                                        </td>
                                        <td class="text-center fw-bold" style="color: #e63946;">
                                            @((item.Amount * item.Movie.Price).ToString("c"))
                                        </td>
                                        <td class="text-end pe-4">
                                            <div class="btn-group shadow-sm">
                                                <a class="btn btn-sm px-2 text-secondary" asp-controller="Orders" asp-action="RemoveItemFromShoppingCart" asp-route-id="@item.Movie.Id">
                                                    <i class="bi bi-dash-circle fs-5"></i>
                                                </a>
                                                <a class="btn btn-sm px-2" asp-controller="Orders" asp-action="AddItemToShoppingCart" asp-route-id="@item.Movie.Id" style="color: #e63946;">
                                                    <i class="bi bi-plus-circle-fill fs-5"></i>
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="card-footer py-5 px-4" style="background-color: #1f1f1f; border-top: 1px solid #252525;">
                        <div class="row align-items-center">
                            <div class="col-sm-6 text-center text-sm-start mb-4 mb-sm-0">
                                <h6 class="text-uppercase mb-2" style="color: #666; font-size: 0.75rem; letter-spacing: 2px;">TOTAL PAYABLE</h6>
                                <h2 class="fw-bold mb-0" style="color: #fff; font-size: 2.5rem;">@Model.ShoppingCartTotal.ToString("c")</h2>
                            </div>
                            <div class="col-sm-6 text-center text-sm-end">
                                @* تم تغيير PayPal بـ زرار مباشر *@
                                <a class="btn btn-danger btn-lg px-5 py-3 rounded-pill fw-bold text-uppercase shadow"
                                   style="letter-spacing: 1px; background-color: #e63946; border: none;"
                                   asp-controller="Orders" asp-action="CompleteOrder">
                                    Complete Order <i class="bi bi-check-circle-fill ms-2"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>