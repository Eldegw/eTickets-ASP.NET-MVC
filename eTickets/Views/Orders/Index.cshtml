@model List<Order>

@{
    ViewData["Title"] = "My Orders";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    body {
        background-color: #080808;
        color: white;
    }

    .orders-wrapper {
        padding: 50px 0;
    }

    .glass-card {
        background: rgba(255, 255, 255, 0.02);
        backdrop-filter: blur(15px);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 25px;
        padding: 20px;
        box-shadow: 0 25px 50px rgba(0,0,0,0.5);
    }

    .custom-table {
        color: #fff;
        vertical-align: middle;
    }

        .custom-table thead th {
            color: #e50914; /* أحمر البراند */
            border: none;
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 2px;
            padding: 20px;
        }

        .custom-table tbody td {
            border-top: 1px solid rgba(255, 255, 255, 0.05);
            padding: 20px;
        }

    .movie-item {
        background: rgba(229, 9, 20, 0.05);
        border: 1px solid rgba(229, 9, 20, 0.2);
        border-radius: 8px;
        padding: 5px 12px;
        margin-bottom: 5px;
        display: block;
        width: fit-content;
        font-size: 0.85rem;
    }

    .price-tag {
        color: #28a745;
        font-weight: 700;
    }

    .status-badge {
        background: rgba(40, 167, 69, 0.1);
        color: #28a745;
        border: 1px solid rgba(40, 167, 69, 0.2);
        padding: 6px 15px;
        border-radius: 50px;
        font-size: 0.75rem;
        text-transform: uppercase;
        font-weight: 700;
    }
</style>

<div class="container orders-wrapper">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-black m-0">ORDER HISTORY</h2>
            <p class="text-muted small">Manage and track your digital movie tickets.</p>
        </div>
        <i class="bi bi-ticket-detailed text-danger fs-1"></i>
    </div>

    <div class="glass-card">
        <div class="table-responsive">
            <table class="table custom-table">
                <thead>
                    <tr>
                        <th>Order Ref</th>
                        <th>Purchased Movies</th>
                        <th>Total Price</th>
                        @if (User.IsInRole("Admin"))
                        {
                            <th>Customer Email</th>
                        }
                        <th class="text-center">Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model)
                    {
                        <tr>
                            <td class="font-monospace text-muted">
                                #@order.Id.ToString().PadLeft(5, '0')
                            </td>
                            <td>
                                @foreach (var item in order.OrderItems)
                                {
                                    <div class="movie-item">
                                        <span class="text-danger fw-bold">@item.Amount x</span> @item.Movie.Name
                                    </div>
                                }
                            </td>
                            <td>
                                <span class="price-tag">
                                    @order.OrderItems.Sum(i => i.Price * i.Amount).ToString("c")
                                </span>
                            </td>
                            @if (User.IsInRole("Admin"))
                            {
                                <td>
                                    <small class="text-white-50">@order.Email</small>
                                </td>
                            }
                            <td class="text-center">
                                <span class="status-badge">
                                    <i class="bi bi-shield-check me-1"></i> Completed
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>