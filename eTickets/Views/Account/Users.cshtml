@model IEnumerable<ApplicationUser>

@{
    ViewData["Title"] = "User Management";
}

<style>
    body {
        background-color: #050505;
        color: white;
    }

    .premium-table-card {
        background: rgba(15, 15, 15, 0.9);
        backdrop-filter: blur(15px);
        border: 1px solid rgba(255, 0, 0, 0.2);
        border-radius: 20px;
        padding: 30px;
        box-shadow: 0 15px 35px rgba(0,0,0,0.5);
    }

    .table {
        color: #e0e0e0 !important;
        border-collapse: separate;
        border-spacing: 0 10px;
    }

        .table thead th {
            background: transparent;
            border: none;
            color: #ff3131;
            text-transform: uppercase;
            font-size: 0.85rem;
            letter-spacing: 1px;
            padding-bottom: 20px;
        }

    .user-row {
        background: rgba(255, 255, 255, 0.03);
        transition: 0.3s;
    }

        .user-row:hover {
            background: rgba(255, 0, 0, 0.08);
            transform: scale(1.005);
        }

        .user-row td {
            padding: 20px;
            border: none;
            vertical-align: middle;
        }

            .user-row td:first-child {
                border-radius: 12px 0 0 12px;
            }

            .user-row td:last-child {
                border-radius: 0 12px 12px 0;
            }

    .avatar-circle {
        width: 45px;
        height: 45px;
        background: linear-gradient(45deg, #ff0000, #8b0000);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        color: white;
        margin-right: 15px;
    }

    .role-badge {
        background: rgba(255, 49, 49, 0.1);
        color: #ff3131;
        border: 1px solid rgba(255, 49, 49, 0.3);
        padding: 5px 12px;
        border-radius: 8px;
        font-size: 0.75rem;
    }

    .page-header h2 {
        font-family: 'Orbitron', sans-serif;
        color: #ff3131;
        text-shadow: 0 0 10px rgba(255, 0, 0, 0.3);
    }
</style>

<div class="container py-5">
    <div class="page-header mb-5 d-flex justify-content-between align-items-center">
        <div>
            <h2 class="mb-1">Platform <span class="text-white">Users</span></h2>
            <p class="text-secondary small">Manage and view all registered community members</p>
        </div>
        <div class="text-white-50">
            <i class="bi bi-people fs-1"></i>
        </div>
    </div>

    <div class="premium-table-card">
        <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th>User Info</th>
                        <th>Username</th>
                        <th>Email Address</th>
                        <th class="text-center">Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr class="user-row shadow-sm">
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="avatar-circle">
                                        @user.FullName.Substring(0, 1).ToUpper()
                                    </div>
                                    <div>
                                        <div class="fw-bold text-white">@user.FullName</div>
                                        <div class="text-muted small">ID: @user.Id.ToString().Substring(0, 8)...</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="text-white-50">@@@user.UserName</span>
                            </td>
                            <td>
                                <i class="bi bi-envelope text-danger me-2"></i>@user.Email
                            </td>
                            <td class="text-center">
                                <span class="role-badge">
                                    <i class="bi bi-shield-check me-1"></i> Verified Member
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>