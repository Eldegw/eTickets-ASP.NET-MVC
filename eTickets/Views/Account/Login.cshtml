@using eTickets.Data.ViewModels;
@model LoginVM

@{
    ViewData["Title"] = "Log in to your account";
}

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<div class="login-page">
    <div class="login-card">
        <div class="card-header-custom">
            <div class="logo-circle">
                <i class="bi bi-person-lock"></i>
            </div>
            <h2>Welcome <span class="highlight">Back</span></h2>
            <p>Please enter your details to sign in</p>
        </div>

        @if (TempData["Error"] != null)
        {
            <div class="custom-alert">
                <i class="bi bi-exclamation-circle-fill"></i>
                <span>@TempData["Error"]</span>
            </div>
        }

        <form asp-controller="Account" asp-action="SaveLogin" method="post">
            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            <div class="input-wrapper">
                <label asp-for="EmailAddress">Email Address</label>
                <div class="input-field">
                    <i class="bi bi-envelope-at"></i>
                    <input asp-for="EmailAddress" placeholder="e.g. name@company.com" />
                </div>
                <span asp-validation-for="EmailAddress" class="error-msg"></span>
            </div>

            <div class="input-wrapper">
                <div class="label-row">
                    <label asp-for="Password">Password</label>
                </div>
                <div class="input-field">
                    <i class="bi bi-shield-lock"></i>
                    <input asp-for="Password" type="password" placeholder="Enter your password" />
                </div>
                <span asp-validation-for="Password" class="error-msg"></span>
            </div>

            <div class="button-group">
                <button type="submit" class="btn-primary-custom">
                    <span>SIGN IN</span>
                    <i class="bi bi-arrow-right-short"></i>
                </button>
                <a asp-controller="Movies" asp-action="Index" class="btn-link-custom">
                    Return to Home
                </a>
            </div>
        </form>

        <div class="card-footer-custom">
            <p>New member? <a asp-action="Register">Create an account</a></p>
        </div>
    </div>
</div>

<style>
    :root {
        --primary-red: #e63946;
        --dark-bg: #0a0a0b;
        --card-bg: #141417;
        --text-main: #ffffff;
        --text-dim: #a0a0a0;
        --input-stroke: #2d2d32;
    }

    .login-page {
        background: radial-gradient(circle at top right, #1a1a1f, var(--dark-bg));
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: 'Inter', sans-serif;
        padding: 20px;
    }

    .login-card {
        background: var(--card-bg);
        width: 100%;
        max-width: 450px;
        padding: 45px;
        border-radius: 24px;
        border: 1px solid rgba(255, 255, 255, 0.05);
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    }

    .card-header-custom {
        text-align: center;
        margin-bottom: 35px;
    }

    .logo-circle {
        width: 60px;
        height: 60px;
        background: rgba(230, 57, 70, 0.1);
        color: var(--primary-red);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 28px;
        margin: 0 auto 20px;
    }

    h2 {
        font-weight: 800;
        color: var(--text-main);
        letter-spacing: -0.5px;
        margin-bottom: 8px;
    }

        h2 .highlight {
            color: var(--primary-red);
        }

    p {
        color: var(--text-dim);
        font-size: 0.95rem;
    }

    .input-wrapper {
        margin-bottom: 24px;
    }

    label {
        display: block;
        color: var(--text-main);
        font-weight: 600;
        font-size: 0.85rem;
        margin-bottom: 10px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .input-field {
        background: #1d1d21;
        border: 1.5px solid var(--input-stroke);
        border-radius: 12px;
        display: flex;
        align-items: center;
        padding: 4px 16px;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

        .input-field i {
            color: var(--text-dim);
            font-size: 1.2rem;
            margin-right: 12px;
        }

        .input-field input {
            background: transparent;
            border: none;
            color: white;
            padding: 12px 0;
            width: 100%;
            outline: none;
            font-size: 1rem;
        }

        .input-field:focus-within {
            border-color: var(--primary-red);
            background: #232329;
            box-shadow: 0 0 0 4px rgba(230, 57, 70, 0.15);
        }

    .btn-primary-custom {
        background: var(--primary-red);
        color: white;
        border: none;
        padding: 16px;
        border-radius: 12px;
        font-weight: 700;
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        transition: 0.3s;
        cursor: pointer;
        margin-top: 10px;
    }

        .btn-primary-custom:hover {
            background: #ff4d5a;
            transform: translateY(-2px);
        }

    .btn-link-custom {
        display: block;
        text-align: center;
        color: var(--text-dim);
        text-decoration: none;
        font-size: 0.9rem;
        margin-top: 15px;
    }

        .btn-link-custom:hover {
            color: white;
        }

    .custom-alert {
        background: rgba(230, 57, 70, 0.15);
        color: #ff8a93;
        padding: 14px;
        border-radius: 10px;
        border-left: 4px solid var(--primary-red);
        margin-bottom: 25px;
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 0.9rem;
    }

    .error-msg {
        color: var(--primary-red);
        font-size: 0.75rem;
        margin-top: 6px;
        display: block;
        font-weight: 500;
    }

    .card-footer-custom {
        margin-top: 35px;
        padding-top: 25px;
        border-top: 1px solid var(--input-stroke);
        text-align: center;
        font-size: 0.9rem;
    }

        .card-footer-custom a {
            color: var(--primary-red);
            text-decoration: none;
            font-weight: 700;
        }
</style>