@{
    ViewData["Title"] = "Registration Successful";
}

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<div class="complete-page">
    <div class="status-card shadow-lg">
        <div class="success-icon-wrapper">
            <div class="check-circle">
                <i class="bi bi-check-lg"></i>
            </div>
            <div class="pulse-ring"></div>
        </div>

        <div class="content">
            <h1>Account <span class="highlight">Created!</span></h1>
            <p>Welcome to the premium eTickets community. Your account has been set up successfully and you're ready to explore the latest movies.</p>
        </div>

        <div class="action-buttons">
            <a asp-controller="Movies" asp-action="Index" class="btn-main">
                <span>Start Exploring</span>
                <i class="bi bi-arrow-right"></i>
            </a>
            <p class="auto-redirect">You will be redirected to home in <span id="timer">5</span>s</p>
        </div>
    </div>
</div>

<style>
    :root {
        /* تم تغيير الأحمر إلى أخضر زمردي جذاب */
        --primary-green: #2ecc71;
        --dark-green: #27ae60;
        --dark-bg: #0a0a0b;
        --card-bg: #141417;
    }

    .complete-page {
        background: radial-gradient(circle at center, #1a1a1f, var(--dark-bg));
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: 'Inter', sans-serif;
    }

    .status-card {
        background: var(--card-bg);
        padding: 60px 40px;
        border-radius: 30px;
        text-align: center;
        max-width: 500px;
        border: 1px solid rgba(46, 204, 113, 0.1); /* لمحة خضراء خفيفة على الإطار */
        position: relative;
        overflow: hidden;
    }

    .success-icon-wrapper {
        position: relative;
        width: 100px;
        height: 100px;
        margin: 0 auto 30px;
    }

    .check-circle {
        width: 100px;
        height: 100px;
        background: var(--primary-green);
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 50px;
        position: relative;
        z-index: 2;
        box-shadow: 0 0 30px rgba(46, 204, 113, 0.4);
        animation: scaleIn 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

    .pulse-ring {
        position: absolute;
        top: 0;
        left: 0;
        width: 100px;
        height: 100px;
        border: 4px solid var(--primary-green);
        border-radius: 50%;
        animation: pulse 2s infinite;
    }

    h1 {
        color: white;
        font-weight: 800;
        margin-bottom: 15px;
    }

        h1 .highlight {
            color: var(--primary-green);
        }
    /* النص المميز بالأخضر */

    p {
        color: #a0a0a0;
        line-height: 1.6;
        font-size: 1rem;
    }

    .btn-main {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        background: var(--primary-green);
        color: white;
        text-decoration: none;
        padding: 15px 35px;
        border-radius: 12px;
        font-weight: 700;
        margin-top: 30px;
        transition: 0.3s;
    }

        .btn-main:hover {
            background: var(--dark-green);
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(46, 204, 113, 0.2);
            color: white;
        }

    .auto-redirect {
        margin-top: 20px;
        font-size: 0.85rem;
        color: #555;
    }

    @@keyframes scaleIn {
        from {
            transform: scale(0);
        }

        to {
            transform: scale(1);
        }
    }

    @@keyframes pulse {
        0% {
            transform: scale(1);
            opacity: 0.5;
        }

        100% {
            transform: scale(1.6);
            opacity: 0;
        }
    }
</style>

@section Scripts {
    <script>
        let count = 5;
        const timerElement = document.getElementById('timer');

        const countdown = setInterval(() => {
            count--;
            timerElement.textContent = count;
            if (count <= 0) {
                clearInterval(countdown);
                window.location.href = '@Url.Action("Index", "Movies")';
            }
        }, 1000);
    </script>
}